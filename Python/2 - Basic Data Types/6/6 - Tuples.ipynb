     ]
    }
   ],
   "source": [
    "if __name__ == '__main__':\n",
    "    n = int(input())  # Read the integer input for number of elements\n",
    "    t = tuple(map(int, input().split()))  # Read space-separated integers and create a tuple\n",
    "    print (hash(t))  # Compute and print the hash of the tuple\n"
   ]
